# Copy this file to .env and fill in your values.
# All variables have defaults; only override what differs from your setup.

# Django
DEBUG=True
ALLOWED_HOSTS=*

# PostgreSQL
DB_NAME=review
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_QUEUE=file_parsing

# RabbitMQ
MQ_HOST=localhost
MQ_PORT=5672
MQ_USERNAME=guest
MQ_PASSWORD=guest
MQ_VIRTUAL_HOST=/
MQ_QUEUE_NAME=task_master
MQ_QUEUE_NAME_LLM_TEST=llm_test

# Email (used for registration verification codes)
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=yourpassword
VERIFICATION_CODE_EXPIRE=300

# Application
# Comma-separated list of usernames that are granted superuser on registration
SUPER_USER_LIST=
MAX_UPLOAD_FILES=5
# Maximum file size in MB
MAX_FILE_SIZE=10
DOMAIN_NAME=http://localhost:8000

# AWS S3 file storage (set USE_S3=True in production to store uploads on S3)
# On EC2, credentials are resolved automatically via the instance IAM role — no keys needed.
USE_S3=False
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Default LLM configuration (used when no active provider is configured)
DEFAULT_MODEL_NAME=qwen3-32b
DEFAULT_MODEL_URL=qwen3-32b
DEFAULT_TEMPERATURE=0.7
DEFAULT_FREQUENCY_PENALTY=0.0
DEFAULT_TOP_P=1.0
DEFAULT_CHUNK_LENGTH=8192
